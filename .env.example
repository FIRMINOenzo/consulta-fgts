# Server
PORT=3000

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="your-jwt-secret-here"

# Admin user (seeded on first startup)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"
ADMIN_NAME="Admin"

# V8 Digital API
V8_CLIENT_ID="your-v8-client-id"
V8_CLIENT_SECRET="your-v8-client-secret"
V8_USERNAME="your-v8-username"
V8_PASSWORD="your-v8-password"

# Processing
SUBMIT_CONCURRENCY=5

# Webhook (public URL for V8 callbacks, e.g. ngrok URL)
WEBHOOK_BASE_URL="https://your-domain.ngrok.io"
